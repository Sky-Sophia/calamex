{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "session",
    "description": "会话快照持久化域能力：编辑器 tab 与视图态持久化。对应 store 插件操作：load/get/set/save/delete。",
    "windows": [
        "main"
    ],
    "permissions": [
        "store:allow-load",
        "store:allow-get",
        "store:allow-set",
        "store:allow-save",
        "store:allow-delete"
    ]
}